{
  "configurations": [
    {
      "name": "ESP-IDF",
      "compilerPath": "${default}",
      "compileCommands": "${workspaceFolder}/build/compile_commands.json",
      "includePath": [
        "${workspaceFolder}/**",
        "${workspaceFolder}/build/config",
        "D:/esp/Espressif/frameworks/esp-idf-v5.3.3/components/**"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "D:/esp/Espressif/frameworks/esp-idf-v5.3.3/components"
        ],
        "limitSymbolsToIncludedHeaders": false
      }
    }
  ],
  "version": 4
}